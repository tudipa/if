{
  "name": "jurusan-informatika-uhn-homepage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "d1:schema": "wrangler d1 execute if-cms --local --file=./d1/schema.sql",
    "d1:seed": "wrangler d1 execute if-cms --local --file=./d1/seed.sql",
    "d1:schema:remote": "wrangler d1 execute if-cms --remote --file=./d1/schema.sql",
    "d1:seed:remote": "wrangler d1 execute if-cms --remote --file=./d1/seed.sql",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.10.1",
    "@tanstack/react-query": "^5.101.0",
    "lucide-react": "^0.468.0",
    "next": "^15.5.19",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260609.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "^20.17.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.49",
    "prisma": "^6.10.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "wrangler": "^4.99.0"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  }
}
